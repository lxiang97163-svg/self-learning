# SQLite（本地开发默认）
DATABASE_URL="file:./dev.db"

# NextAuth — 生产环境请使用强随机串，勿提交 .env
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# 平台服务费比例（0.08 = 8%），服务端用于试算
PLATFORM_FEE_RATE="0.08"

# 可选：种子脚本创建管理员（npm run db:seed）
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe_Strong!"

# 可选：E2E 基址（须与 NEXTAUTH_URL 主机名一致，勿混用 127.0.0.1 与 localhost）
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# 可选：E2E 使用本机 Edge/Chrome，可跳过 `npx playwright install chromium`
# PLAYWRIGHT_CHANNEL=msedge
# PLAYWRIGHT_CHANNEL=chrome
